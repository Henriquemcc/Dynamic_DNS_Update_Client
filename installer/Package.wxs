<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
    <Package Name="Dynamic DNS Update Client"
    Manufacturer="Henrique Mendonça Castelar Campos"
    Version="$(var.ProductVersion)"
    UpgradeCode="5368c52b-c334-4269-a36c-1d8b2d615e90">
    
    <!-- Manages the removal of old versions automatically -->
    <MajorUpgrade DowngradeErrorMessage="A recent version is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main">
      <ComponentGroupRef Id="AppComponents" />
    </Feature>

    <!-- Checks if the environment variable JAVA_HOME is defined. If it's not, blocks the installation. -->
    <Launch Message="Java Runtime Environment version 17 or later is needed to install this application. To download, access: https://adoptium.net/temurin/releases" Condition="Installed OR %JAVA_HOME" />
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Dynamic DNS Update Client" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">
      <Component Id="ServiceComponent">
        <File Source="../app/build/launch4j/app.exe" KeyPath="yes" />
        <ServiceInstall
        Id="DDUCServiceInstaller"
        Type="ownProcess"
        Name="DynamicDnsUpdateClientService"
        DisplayName="Dynamic DNS Update Client"
        Description="Automatically updates the IP address of Dynamic DNS services."
        Start="auto"
        ErrorControl="normal"
        Account="LocalSystem"
        Interactive="no"
        Arguments="daemon" />
        <ServiceControl
        Id="DDUCStartService"
        Name="DynamicDnsUpdateClientService"
        Stop="both"
        Remove="uninstall"
        Wait="yes"/>
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>